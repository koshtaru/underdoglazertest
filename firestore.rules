rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Gallery collection - Allow read access for public gallery
    // Allow write access for authenticated admin users only
    match /gallery/{document} {
      // Allow read access for everyone (public gallery needs this)
      allow read: if true;
      
      // Allow write access only for authenticated users
      // In production, you may want to add more specific role-based access
      allow write: if request.auth != null;
    }
    
    // Default rule - deny access to all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}